# =============================================================================
# secrets.env - Environment variables for Containerbot
# =============================================================================

# Telegram bot token (required - get from @BotFather)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# RBAC: Comma-separated Telegram user IDs
# Admins can: reload, upload scripts, run admin-only scripts
# Users can:  browse menu, run non-admin scripts
# If BOTH are empty, everyone is allowed (dev mode)
ALLOWED_ADMINS=YOUR-TELEGRAM-ID
ALLOWED_USERS=YOUR-TELEGRAM-ID

# Explicitly allow admin uploads of new .sh/.py scripts
ENABLE_SCRIPT_UPLOAD=false

# Management network probe (entrypoint waits for this IP before starting)
MGMT_PROBE_IP=10.99.1.2

# Seconds to wait after mgmt network is up
POST_BOOT_SLEEP=30

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
